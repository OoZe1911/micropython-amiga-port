static inline __attribute__((__stkparm__)) int memcmp(const void *s1,const void *s2,size_t n)
{
 const unsigned char *p1, *p2;

 p1 = (const unsigned char *) s1;
 p2 = (const unsigned char *) s2;
 while(n-- > 0) {
  unsigned char a, b;

  if (*p1++ == *p2++)
  continue;

  a = *--p1;
  b = *--p2;
  return (short)a - b;
 }
 return 0;
}

static inline __attribute__((__stkparm__)) void *memchr(const void *s,int c,size_t n)
{
 if (n) {
  unsigned char *p=(unsigned char *)s;
  do {
   if (*p++==(unsigned char)c)
   return --p;
  }while(--n);
 }
 return (void *)n;
}

static inline __attribute__((__stkparm__)) size_t strlen(const char *string)
{ const char *s=string;

 while(*s++) {}return ~(string-s);
}

static inline __attribute__((__stkparm__)) size_t strlen_plus_one(const char *string)
{ const char *s=string;

 while(*s++) {}return (s-string);
}

static inline __attribute__((__stkparm__)) char *strcpy(char *s1,const char *s2)
{ char *s=s1;
 while((*s1++=*s2++)) {}
 return s;
}

static inline __attribute__((__stkparm__)) char *strlwr(char *s)
{ unsigned char *s1=(unsigned char *)s;

 while(*s1) {
  if ((*s1>('A'-1)) && (*s1<('Z'+1)))
  *s1+='a'-'A';
  s1++;
 }
 return s;
}

static inline __attribute__((__stkparm__)) char *stpcpy(char *dst,const char *src)
{
 while((*dst++=*src++)){} return(--dst);
}

static inline __attribute__((__stkparm__)) void *mempcpy(void *to, const void *from, size_t sz) {
 return sz + (char *)memcpy(to, from, sz);
}
